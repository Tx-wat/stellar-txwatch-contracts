{
  "name": "@tx-wat/watcher-registry",
  "version": "0.1.0",
  "description": "TypeScript bindings for the stellar-txwatch WatcherRegistry Soroban contract",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "soroban",
    "smart-contract",
    "watcher-registry",
    "txwatch",
    "blockchain"
  ],
  "author": "Tx-wat <https://github.com/Tx-wat>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tx-wat/stellar-txwatch-contracts.git",
    "directory": "bindings/watcher-registry"
  },
  "homepage": "https://github.com/Tx-wat/stellar-txwatch-contracts#readme",
  "bugs": {
    "url": "https://github.com/Tx-wat/stellar-txwatch-contracts/issues"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "12.3.0",
    "typescript": "5.4.5"
  }
}
